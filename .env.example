# All of these are read server-side only, by server/index.js (which starts
# the connectors in server/connectors/ -- see server/scheduler.js). None are
# ever exposed to the browser bundle -- that's why none are VITE_-prefixed.
#
# Not listed below because they need no key at all: Feodo Tracker, OpenPhish,
# Emerging Threats (Proofpoint), Spamhaus DROP, and the CVE Program's own
# cve.org delta feed -- all four are public plain-text/JSON feeds with no
# registration.

# --- Bulk/background sources -------------------------------------------

# Optional. Free key from https://nvd.nist.gov/developers/request-an-api-key
# Raises the NVD CVE API rate limit from 5 requests/30s to 50 requests/30s.
NVD_API_KEY=

# Recommended. Free key from https://auth.abuse.ch/, shared across abuse.ch's
# ThreatFox, URLHaus and MalwareBazaar APIs (they unified auth in 2023-2024 --
# URLHaus used to be keyless but no longer is, confirmed against the live
# API). Without it, those three panels show a "not configured" message and
# the Threat Feed falls back to Feodo Tracker + OpenPhish (both keyless).
ABUSECH_AUTH_KEY=

# Optional. Free key from https://otx.alienvault.com/ (Settings -> API
# Integration). Powers OTX pulse IOCs in the Threat Feed and the OTX-tagged
# half of Threat Actor Activity. Without it, that connector reports
# "not configured" and is skipped.
OTX_API_KEY=

# Optional. Free key from https://www.abuseipdb.com/register (free tier: a
# daily quota of lookups + a bulk /blacklist endpoint). Powers "Top Malicious
# IPs" via the Threat Feed. Without it, this source is skipped.
ABUSEIPDB_API_KEY=

# Optional. Free key from https://pulsedive.com/ -- confirmed live that
# Pulsedive's explore/info endpoints actually work without a key at all, but
# an anonymous IP shares a much lower rate limit than a registered one. Powers
# a "risk=high" slice of the Threat Feed and doubles as an IOC Search lookup
# (ip/domain/url; no file-hash support).
PULSEDIVE_API_KEY=

# Required for the bulk feed. Free key from https://phishtank.org/ (register,
# then find it under your profile). Confirmed live: anonymous downloads are
# now capped at 75 requests/3 days and routed through a CDN that 404s without
# a key, so this source reports "not configured" until one is set.
PHISHTANK_API_KEY=

# Strongly recommended (works without one, but barely). Free personal access
# token from https://github.com/settings/tokens -- no scopes needed for
# public data. Confirmed live: raises GitHub's Search API limit from 10 to 30
# req/min, and the REST ("core") limit from 60 to 5000 req/hr. Powers
# server/githubIntel/ (repo discovery, content fetch, IOC/CVE/ATT&CK
# extraction, correlation, threat scoring), and the YARA-Rules/SigmaHQ
# detection-rule sync (server/connectors/detectionRules.js), which reuses the
# same GitHub client. Without it, discovery/enrichment still run, just much
# slower and more likely to hit 429s mid-cycle.
GITHUB_TOKEN=

# Optional. Free Community API key from https://vulncheck.com/ (Community
# tier -- registration required, no cost). Powers a second, larger exploited-
# CVE catalog (VulnCheck KEV, confirmed live at api.vulncheck.com/v3/index/
# vulncheck-kev) alongside CISA's own KEV -- 2,500+ tracked CVEs with linked
# exploit references, vs CISA's ~1,300. Without it, this source reports
# "not configured" and is skipped, same pattern as OTX/AbuseIPDB/etc.
VULNCHECK_API_KEY=

# --- Keyless bulk/background sources (no registration, nothing to set) --
#
# Exploit-DB (server/connectors/exploitdb.js) -- free CSV mirror of Exploit-DB,
# CVE<->PoC-maturity correlation, no auth.
# YARA-Rules + SigmaHQ (server/connectors/detectionRules.js) -- free,
# community-maintained detection-rule repos, filename-based family index.

# --- IOC Search only (single-indicator lookups, not bulk feeds) ---------

# Optional. Free key from https://www.virustotal.com/gui/join-us (free tier:
# 4 req/min, 500/day). Used live when you search an indicator in IOC Search --
# never polled/cached in bulk.
VIRUSTOTAL_API_KEY=

# Optional. Free Community API key from https://viz.greynoise.io/ -- IP
# lookups only. Used live in IOC Search.
GREYNOISE_API_KEY=

# Optional. Free key from https://account.shodan.io/register -- IP lookups
# only, the most limited free tier of the five. Used live in IOC Search.
SHODAN_API_KEY=

# Optional. Free key from https://hybrid-analysis.com/ (Falcon Sandbox
# self-service account -> Profile -> API Key). Confirmed live that the old
# bulk "recent samples" feed no longer exists (404); only the hash-lookup
# endpoint is still live, so this is file-hash lookups only in IOC Search.
HYBRID_ANALYSIS_API_KEY=

# Optional. Free key from https://leakix.net/ (register -> account -> API
# key). IP/domain lookups only -- exposed-service and leaked-data OSINT
# search, confirmed live via /host/{ip} and /search?scope=service|leak.
LEAKIX_API_KEY=

# The following four IOC Search sources need no key at all (confirmed live,
# keyless, no registration) -- listed here for completeness, not because
# there's anything to set:
#   - crt.sh (server/lookups/crtsh.js) -- domain lookups, certificate
#     transparency log search / subdomain discovery.
#   - RIPEstat (server/lookups/ripestat.js) -- IP lookups, ASN/prefix/holder.
#   - Team Cymru (server/lookups/teamCymru.js) -- IP + hash lookups, via DNS
#     TXT queries (IP-to-ASN and the Malware Hash Registry), not REST.
#   - Hudson Rock Cavalier (server/lookups/hudsonRock.js) -- domain lookups,
#     free infostealer-exposure intelligence.

# --- AI Assistant (local RAG chatbot, see server/rag/) ------------------
# No key, no account, no cost -- these just point at a local Ollama install
# (https://ollama.com/download, free). After installing, pull both models
# once: `ollama pull llama3.1:8b` and `ollama pull nomic-embed-text`. Leave
# these unset to use the defaults shown below; the AI Assistant tab reports
# itself as unavailable (with exact setup instructions) until Ollama is
# running and both models are pulled -- nothing else in the dashboard depends
# on this.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Port the backend (server/index.js) listens on. Vite's dev proxy also reads
# this to know where to forward /api/* -- see vite.config.ts.
PORT=8080
